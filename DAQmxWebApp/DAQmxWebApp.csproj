<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DAQmxWebApp</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore" Version="2.63.0" />
    <PackageReference Include="Grpc.Net.Client" Version="2.63.0" />
    <PackageReference Include="Google.Protobuf" Version="3.27.3" />
    <PackageReference Include="Grpc.Tools" Version="2.63.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="Protos\nidaqmx.proto"              GrpcServices="Client" ProtoRoot="Protos" />
    <Protobuf Include="Protos\session.proto"               GrpcServices="None"   ProtoRoot="Protos" />
    <Protobuf Include="Protos\data_moniker.proto"          GrpcServices="Client" ProtoRoot="Protos" />
    <Protobuf Include="Protos\ni\protobuf\types\waveform.proto"            GrpcServices="None" ProtoRoot="Protos" />
    <Protobuf Include="Protos\ni\protobuf\types\precision_timestamp.proto" GrpcServices="None" ProtoRoot="Protos" />
  </ItemGroup>

</Project>
